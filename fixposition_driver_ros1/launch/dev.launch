<launch>
    <env name="ROSCONSOLE_CONFIG_FILE" value="$(find fixposition_driver_ros1)/launch/rosconsole_dev.conf"/>
    <node name="fixposition_driver_ros1" pkg="fixposition_driver_ros1" type="fixposition_driver_ros1" output="screen" respawn="false" respawn_delay="5">
        <rosparam command="load" file="$(find fixposition_driver_ros1)/launch/config.yaml"/>
    </node>
</launch>
